#[cfg(test)]
mod tests {
    use super::*;

    #[test]
    fn example() {
        let nums = vec![2, 7, 11, 15];
        let target = 9;
        let expected = vec![0, 1];
        // Because nums[0] + nums[1] == 9.
        assert_eq!(two_sum(nums, target), expected);
    }
