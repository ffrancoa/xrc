=== tests/cli.rs ===
use assert_cmd::Command;
use indoc::indoc;

#[test]
fn test_cli() {
    let input = indoc! {"
        1 2
    "};
    let expected = indoc! {"
        3
    "};

    Command::cargo_bin("a_plus_b").unwrap()
        .write_stdin(input)
        .assert()
        .stdout(expected);
    let input = indoc! {"
        3 4
    "};
    let expected = indoc! {"
        7
    "};

    Command::cargo_bin("a_plus_b").unwrap()
        .write_stdin(input)
        .assert()
        .stdout(expected);
}
